  "paths": {
    "contract": "paths",
    "version": "1.1.0",
    "socketPath": "/run/horsey/baby-quirt.sock",
    "configRoot": "/etc/baby-quirt",
    "stateRoot": "/var/lib/baby-quirt",
    "releaseRoot": "/opt/baby-quirt/releases",
    "currentLink": "/opt/baby-quirt/current",
    "previousLink": "/opt/baby-quirt/previous",
    "artifactUploadRoot": "/var/lib/baby-quirt/artifacts/uploads",
    "artifactObjectRoot": "/var/lib/baby-quirt/artifacts/sha256"
  },
  "receipt": {
    "contract": "receipt",
    "version": "2.0.0",
    "emittedSchemaVersion": "2.0.0",
    "acceptedSchemaVersions": [
      "1.0.0",
      "2.0.0"
    ],
    "algorithm": "ed25519",
    "requestBinding": [
      "requestDigest",
      "requestFingerprint"
    ],
    "resultBinding": [
      "resultDigest"
    ],
    "runtimeBinding": [
      "machineIdSha256",
      "hostname",
      "release"
    ],
    "timingBinding": [
      "startedAt",
      "completedAt",
      "timestamp"
    ],
    "secretPolicy": "secret_values_forbidden"
  },
  "release": {
    "contract": "release",
    "version": "1.0.0",
    "immutableReleases": true,
    "manifestRequired": true,
    "digestAlgorithm": "sha256"
  },
  "rollback": {
    "contract": "rollback",
    "version": "1.0.0",
    "previousPointerRequired": true,
    "automaticOnVerificationFailure": true
  },
  "clientInvocation": {
    "tool": "bbyquirt.call_quirt",
    "actionDescription": "Run any authorized Baby Quirt operation through the single authenticated Baby Quirt interface.",
    "variableFields": [
      "operation",
      "payload",
      "idempotencyKey"
    ],
    "discoveryOperation": "baby.describe",
    "confirmationAuthority": "chatgpt_platform"
  },
  "idempotency": {
    "contract": "idempotency",
    "version": "2.0.0",
