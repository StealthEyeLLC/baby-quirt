{
  "schemaVersion": "1.2.0",
  "contractVersion": "1.2.0",
  "product": {
    "name": "baby-quirt",
    "description": "Standalone private Unix-socket host-control runtime for bootstrapping Quirt",
    "repository": "StealthEyeLLC/baby-quirt",
    "ownerSubject": "stealtheye-owner",
    "authorityClass": "unrestricted-owner"
  },
  "architecture": {
    "contract": "architecture",
    "version": "1.2.0",
    "topology": [
      "Authorized Horsey gateway client",
      "Signed private Baby Quirt protocol (QRT1)",
      "/run/horsey/baby-quirt.sock",
      "Standalone UID-0 Baby Quirt daemon"
    ],
    "babyQuirtOwns": [
      "privileged_local_machine_authority",
      "job_lifecycle",
      "process_execution",
      "pty_sessions",
      "file_operations",
      "artifact_storage",
      "release_installation",
      "rollback_and_repair",
      "capability_discovery",
      "strict_semantic_idempotency",
      "atomic_compare_and_swap_file_replacement",
      "content_addressed_artifact_finalization",
      "request_bound_signed_receipts"
    ],
    "babyQuirtMustNotBecome": [
      "public_control_plane",
      "oauth_server",
      "public_mcp_server",
      "objective_scheduler"
    ]
  },
  "authority": {
    "contract": "authority",
    "version": "1.2.0",
    "ownerSubject": "stealtheye-owner",
    "authorityClass": "unrestricted-owner",
    "issuerMatching": "exact_required",
    "subjectMatching": "exact_required",
    "gatewayId": "stealtheye-horsey-gateway",
    "algorithms": [
      "ed25519"
    ],
    "securityMechanisms": [
      "exact_issuer",
      "exact_subject",
      "authority_class",
      "ed25519_signatures",
      "canonical_encoding",
      "nonces",
      "replay_protection",
      "idempotency",
      "peer_credentials",
      "private_socket_access",
      "signed_receipts",
      "secret_redaction",
      "semantic_request_fingerprints",
      "idempotency_conflict_detection",
      "pre_execution_idempotency_reservations"
    ]
  },
  "protocol": {
    "contract": "protocol",
    "version": "1.0.0",
    "wireVersion": "1.0.0",
    "framing": "QRT1",
    "transport": "unix_socket",
    "socketPath": "/run/horsey/baby-quirt.sock",
    "maxFrameSize": 16777216,
    "compression": [
      "none"
    ],
    "frameTypes": [
      "hello",
      "welcome",
      "request",
      "response",
      "error",
      "event",
      "cancel",
      "ping",
      "pong"
    ]
  },
