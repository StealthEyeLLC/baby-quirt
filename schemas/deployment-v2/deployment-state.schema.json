{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baby-quirt.stealtheye.io/schemas/deployment-v2/deployment-state.schema.json",
  "title": "Baby Quirt Standalone Deployment State v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deploymentId",
    "generation",
    "machineId",
    "planDigest",
    "requestDigest",
    "state",
    "stateSequence",
    "guardArmed",
    "terminal",
    "recordDigest",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "schemaVersion": { "const": "2.0.0" },
    "deploymentId": { "$ref": "#/$defs/identifier" },
    "generation": { "type": "integer", "minimum": 1 },
    "machineId": { "$ref": "#/$defs/identifier" },
    "planDigest": { "$ref": "#/$defs/digest" },
    "requestDigest": { "$ref": "#/$defs/digest" },
    "state": { "$ref": "#/$defs/state" },
    "stateSequence": { "type": "integer", "minimum": 0 },
    "guardArmed": { "type": "boolean" },
    "successMarkerDigest": { "$ref": "#/$defs/digest" },
    "terminal": { "type": "boolean" },
    "recordDigest": { "$ref": "#/$defs/digest" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "state": {
      "type": "string",
      "enum": [
        "requested",
        "source_resolving",
        "source_verified",
        "building",
        "testing",
        "packaging",
        "reproducibility_verifying",
        "artifact_verified",
        "compatibility_verifying",
        "preflight",
        "staging",
        "candidate_verifying",
        "ready_to_activate",
        "snapshotting",
        "guard_arming",
        "guard_armed",
        "gateway_installing",
        "gateway_activating",
        "gateway_accepting_legacy",
        "baby_installing",
        "baby_activating",
        "baby_accepting",
        "restart_accepting",
        "chatgpt_accepting",
        "success_marking",
        "guard_disarming",
        "succeeded",
        "cancel_requested",
        "cancelling",
        "failed",
        "timed_out",
        "partial",
        "ambiguous",
        "unknown",
        "reconciling",
        "rollback_requested",
        "rolling_back",
        "rolled_back",
        "rollback_failed",
        "manual_recovery_required"
      ]
    }
  }
}
