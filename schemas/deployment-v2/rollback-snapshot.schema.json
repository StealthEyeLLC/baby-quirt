{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://baby-quirt.stealtheye.io/schemas/deployment-v2/rollback-snapshot.schema.json",
  "title": "Baby Quirt Rollback Snapshot v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "deploymentId",
    "generation",
    "machineId",
    "planDigest",
    "capturedAt",
    "expectedCurrentPointers",
    "targets",
    "processes",
    "listeners",
    "knownGoodEvidenceDigest",
    "privateRecoveryPayload",
    "snapshotDigest",
    "signatureAlgorithm",
    "signingKeyId",
    "signature"
  ],
  "properties": {
    "schemaVersion": { "const": "2.0.0" },
    "deploymentId": { "$ref": "#/$defs/identifier" },
    "generation": { "type": "integer", "minimum": 1 },
    "machineId": { "$ref": "#/$defs/identifier" },
    "planDigest": { "$ref": "#/$defs/digest" },
    "capturedAt": { "type": "string", "format": "date-time" },
    "expectedCurrentPointers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["baby", "gateway"],
      "properties": {
        "baby": { "$ref": "#/$defs/pointer" },
        "gateway": { "$ref": "#/$defs/pointer" }
      }
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/target" }
    },
    "processes": { "type": "array", "items": { "$ref": "#/$defs/process" } },
    "listeners": { "type": "array", "items": { "$ref": "#/$defs/listener" } },
    "knownGoodEvidenceDigest": { "$ref": "#/$defs/digest" },
    "privateRecoveryPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifactReference", "digest", "rootOnly"],
      "properties": {
        "artifactReference": { "type": "string", "pattern": "^artifact:sha256:[a-f0-9]{64}$" },
        "digest": { "$ref": "#/$defs/digest" },
        "rootOnly": { "const": true }
      }
    },
    "snapshotDigest": { "$ref": "#/$defs/digest" },
    "signatureAlgorithm": { "const": "ed25519" },
    "signingKeyId": { "$ref": "#/$defs/identifier" },
    "signature": { "$ref": "#/$defs/signature" }
  },
  "$defs": {
    "identifier": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$" },
    "digest": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "signature": { "type": "string", "minLength": 32, "pattern": "^[A-Za-z0-9+/]+={0,2}$" },
    "pointer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "target", "inode", "digest"],
      "properties": {
        "path": { "type": "string", "pattern": "^/" },
        "target": { "type": "string", "pattern": "^/" },
        "inode": { "type": "integer", "minimum": 1 },
        "digest": { "$ref": "#/$defs/digest" }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "digest", "owner", "group", "mode", "aclDigest", "xattrDigest", "secretDisposition"],
      "properties": {
        "path": { "type": "string", "pattern": "^/" },
        "kind": { "enum": ["file", "directory", "symlink", "socket-metadata", "oauth-state", "unit", "tmpfiles", "caddy"] },
        "digest": { "$ref": "#/$defs/digest" },
        "owner": { "type": "string", "minLength": 1 },
        "group": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "pattern": "^0[0-7]{3}$" },
        "aclDigest": { "$ref": "#/$defs/digest" },
        "xattrDigest": { "$ref": "#/$defs/digest" },
        "secretDisposition": { "enum": ["none", "fingerprint_only", "private_recovery_payload"] }
      }
    },
    "process": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pid", "startTime", "executable", "uid", "cgroup"],
      "properties": {
        "pid": { "type": "integer", "minimum": 1 },
        "startTime": { "type": "string", "minLength": 1 },
        "executable": { "type": "string", "pattern": "^/" },
        "uid": { "type": "integer", "minimum": 0 },
        "cgroup": { "type": "string", "minLength": 1 }
      }
    },
    "listener": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "address", "port", "processIdentityDigest"],
      "properties": {
        "protocol": { "enum": ["tcp", "udp", "unix"] },
        "address": { "type": "string" },
        "port": { "type": ["integer", "null"], "minimum": 0, "maximum": 65535 },
        "processIdentityDigest": { "$ref": "#/$defs/digest" }
      }
    }
  }
}
