{
  "name": "baby-quirt",
  "version": "0.1.0",
  "description": "Baby Quirt — standalone private Unix-socket host-control runtime",
  "type": "module",
  "engines": {
    "node": "24.18.0"
  },
  "bin": {
    "baby-quirt": "./dist/cli/main.js",
    "baby-quirt-install": "./dist/cli/install.js",
    "baby-quirt-verify": "./dist/cli/verify.js",
    "baby-quirt-rollback": "./dist/cli/rollback.js",
    "baby-quirt-repair": "./dist/cli/repair.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:native": "node-gyp rebuild",
    "clean": "rm -rf dist build",
    "install": "node-gyp rebuild",
    "test": "node --import tsx --test test/**/*.test.ts",
    "test:integration": "node --import tsx --test integration/**/*.test.ts",
    "test:acceptance": "node --import tsx --test acceptance/**/*.test.ts",
    "test:all": "npm run test && npm run test:integration && npm run test:acceptance",
    "test:contracts": "node --import tsx scripts/validate-contracts.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "release:bundle": "bash scripts/release.sh",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "node-addon-api": "^8.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "node-gyp": "^11.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "license": "UNLICENSED",
  "private": true,
  "gypfile": true
}
