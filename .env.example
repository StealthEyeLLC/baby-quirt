# Repository
BABY_QUIRT_REPOSITORY=StealthEyeLLC/baby-quirt
BABY_QUIRT_DEFAULT_BRANCH=main
BABY_QUIRT_WORK_BRANCH=build/quirt-core
BABY_QUIRT_GIT_REMOTE=https://github.com/StealthEyeLLC/baby-quirt.git

# Authorized VPS
BABY_QUIRT_VPS_HOST=51.81.86.225
BABY_QUIRT_VPS_PORT=22
BABY_QUIRT_VPS_USER=ubuntu
BABY_QUIRT_EXPECTED_HOSTNAME=vps-c9f04f5e
BABY_QUIRT_EXPECTED_MACHINE_ID_SHA256=cd189817b39fea60d338b73878240a6fe7db71374c7a0f35ad60f8eb641e8817

# Installed runtime
BABY_QUIRT_NODE_PATH=/opt/node-v24.18.0-linux-x64/bin/node
BABY_QUIRT_SERVICE_NAME=baby-quirt.service
BABY_QUIRT_SOCKET_PATH=/run/horsey/baby-quirt.sock
BABY_QUIRT_SOCKET_GROUP=horsey
BABY_QUIRT_SOCKET_MODE=0660
BABY_QUIRT_GATEWAY_USER=fix-mcp

# Fresh standalone installation
BABY_QUIRT_RELEASE_ROOT=/opt/baby-quirt/releases
BABY_QUIRT_CURRENT_LINK=/opt/baby-quirt/current
BABY_QUIRT_PREVIOUS_LINK=/opt/baby-quirt/previous
BABY_QUIRT_STATE_ROOT=/var/lib/baby-quirt
BABY_QUIRT_CONFIG_ROOT=/etc/baby-quirt

# Horsey identity
BABY_QUIRT_GATEWAY_ID=stealtheye-horsey-gateway
BABY_QUIRT_SUPERVISOR_ID=baby-quirt-supervisor
BABY_QUIRT_EXPECTED_SUBJECT=stealtheye-owner

# Existing private OAuth authority
BABY_QUIRT_OAUTH_ISSUER=https://mcp.stealtheye.io
BABY_QUIRT_OAUTH_RESOURCE=https://mcp.stealtheye.io
BABY_QUIRT_OAUTH_JWKS_URI=https://mcp.stealtheye.io/oauth/jwks.json
